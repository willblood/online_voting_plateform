generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  VOTER
  ADMIN
  OBSERVER
}

enum ElectionType {
  PRESIDENTIAL
  MUNICIPAL
  LEGISLATIVE
  REFERENDUM
}

enum ElectionStatus {
  UPCOMING
  OPEN
  CLOSED
}

// ─── Geography ────────────────────────────────────────────────────────────────

model District {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @unique
  population Int
  area_km2   Decimal?  @db.Decimal(10, 2)
  created_at DateTime? @default(now())

  cities          City[]
  district_results DistrictResult[]

  @@map("districts")
}

model City {
  id          String    @id @default(uuid()) @db.Uuid
  district_id String    @db.Uuid
  name        String
  population  Int
  area_km2    Decimal?  @db.Decimal(10, 2)
  created_at  DateTime? @default(now())

  district     District     @relation(fields: [district_id], references: [id])
  municipalities Municipality[]
  city_results  CityResult[]

  @@map("cities")
}

model Municipality {
  id         String    @id @default(uuid()) @db.Uuid
  city_id    String    @db.Uuid
  name       String
  population Int
  created_at DateTime? @default(now())

  city                  City                   @relation(fields: [city_id], references: [id])
  users                 User[]
  election_registrations ElectionRegistration[]
  municipality_results   MunicipalityResult[]

  @@map("municipalities")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  national_id     String    @unique
  email           String    @unique
  password_hash   String
  role            Role
  municipality_id String    @db.Uuid
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now())
  updated_at      DateTime? @updatedAt

  municipality           Municipality           @relation(fields: [municipality_id], references: [id])
  profile                Profile?
  election_registrations ElectionRegistration[]
  votes                  Vote[]

  @@map("users")
}

model Profile {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String    @unique @db.Uuid
  first_name     String
  last_name      String
  date_of_birth  DateTime  @db.Date
  phone_number   String?
  gender         String?
  created_at     DateTime? @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("profiles")
}

// ─── Elections ────────────────────────────────────────────────────────────────

model Election {
  id          String         @id @default(uuid()) @db.Uuid
  title       String
  type        ElectionType
  description String?
  start_time  DateTime
  end_time    DateTime
  status      ElectionStatus @default(UPCOMING)
  created_at  DateTime?      @default(now())
  updated_at  DateTime?      @updatedAt

  candidates             Candidate[]
  election_registrations ElectionRegistration[]
  votes                  Vote[]
  municipality_results   MunicipalityResult[]
  city_results           CityResult[]
  district_results       DistrictResult[]
  national_results       NationalResult[]

  @@map("elections")
}

model Candidate {
  id          String    @id @default(uuid()) @db.Uuid
  election_id String    @db.Uuid
  first_name  String
  last_name   String
  party_name  String?
  photo_url   String?
  created_at  DateTime? @default(now())

  election             Election             @relation(fields: [election_id], references: [id])
  votes                Vote[]
  municipality_results MunicipalityResult[]
  city_results         CityResult[]
  district_results     DistrictResult[]
  national_results     NationalResult[]

  @@map("candidates")
}

// ─── Registrations & Votes ────────────────────────────────────────────────────

model ElectionRegistration {
  id              String   @id @default(uuid()) @db.Uuid
  election_id     String   @db.Uuid
  user_id         String   @db.Uuid
  municipality_id String   @db.Uuid
  registered_at   DateTime @default(now())

  election     Election     @relation(fields: [election_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])
  municipality Municipality @relation(fields: [municipality_id], references: [id])

  @@unique([election_id, user_id])
  @@map("election_registrations")
}

model Vote {
  id             String   @id @default(uuid()) @db.Uuid
  election_id    String   @db.Uuid
  user_id        String   @db.Uuid
  candidate_id   String   @db.Uuid
  encrypted_vote String
  receipt_code   String   @unique
  created_at     DateTime @default(now())

  election  Election  @relation(fields: [election_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id])
  candidate Candidate @relation(fields: [candidate_id], references: [id])

  @@unique([user_id, election_id])
  @@map("votes")
}

// ─── Results ──────────────────────────────────────────────────────────────────

model MunicipalityResult {
  id                  String   @id @default(uuid()) @db.Uuid
  election_id         String   @db.Uuid
  municipality_id     String   @db.Uuid
  candidate_id        String   @db.Uuid
  votes_count         Int?
  registered_voters   Int?
  turnout_percentage  Decimal? @db.Decimal(5, 2)

  election     Election     @relation(fields: [election_id], references: [id])
  municipality Municipality @relation(fields: [municipality_id], references: [id])
  candidate    Candidate    @relation(fields: [candidate_id], references: [id])

  @@unique([election_id, municipality_id, candidate_id])
  @@map("municipality_results")
}

model CityResult {
  id                 String   @id @default(uuid()) @db.Uuid
  election_id        String   @db.Uuid
  city_id            String   @db.Uuid
  candidate_id       String   @db.Uuid
  votes_count        Int?
  registered_voters  Int?
  turnout_percentage Decimal? @db.Decimal(5, 2)

  election  Election  @relation(fields: [election_id], references: [id])
  city      City      @relation(fields: [city_id], references: [id])
  candidate Candidate @relation(fields: [candidate_id], references: [id])

  @@unique([election_id, city_id, candidate_id])
  @@map("city_results")
}

model DistrictResult {
  id                 String   @id @default(uuid()) @db.Uuid
  election_id        String   @db.Uuid
  district_id        String   @db.Uuid
  candidate_id       String   @db.Uuid
  votes_count        Int?
  registered_voters  Int?
  turnout_percentage Decimal? @db.Decimal(5, 2)

  election  Election  @relation(fields: [election_id], references: [id])
  district  District  @relation(fields: [district_id], references: [id])
  candidate Candidate @relation(fields: [candidate_id], references: [id])

  @@unique([election_id, district_id, candidate_id])
  @@map("district_results")
}

model NationalResult {
  id                 String   @id @default(uuid()) @db.Uuid
  election_id        String   @db.Uuid
  candidate_id       String   @db.Uuid
  votes_count        Int?
  registered_voters  Int?
  turnout_percentage Decimal? @db.Decimal(5, 2)

  election  Election  @relation(fields: [election_id], references: [id])
  candidate Candidate @relation(fields: [candidate_id], references: [id])

  @@unique([election_id, candidate_id])
  @@map("national_results")
}
